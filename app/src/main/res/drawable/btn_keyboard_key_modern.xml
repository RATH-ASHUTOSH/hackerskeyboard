<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/modern_key_glass_pressed" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/modern_key_border" />
            <padding android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="8dp" />
        </shape>
    </item>

    <item android:state_checkable="true" android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/modern_key_glass" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="@color/modern_key_border" />
                    <padding android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="8dp" />
                </shape>
            </item>
            <item android:gravity="bottom|center_horizontal" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <size android:height="3dp" android:width="10dp" />
                    <solid android:color="#00BCD4" /> <corners android:radius="1.5dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/modern_key_border" />
            <padding android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="8dp" />
        </shape>
    </item>

</selector>